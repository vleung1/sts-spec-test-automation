# STS v2 API base URL — ONLY THIS VAR is read by the framework (sts_test_framework.config.sts_base_url).
# Default if unset: https://sts-qa.cancer.gov/v2
# STS_BASE_URL=https://sts-qa.cancer.gov/v2

# Example: prod or another environment (include /v2)
# STS_BASE_URL=https://sts.cancer.gov/v2

# Informational only (not read by code); use STS_BASE_URL for QA
# STS_QA_URL=https://sts-qa.cancer.gov/v2

# Set to false to disable SSL verification (e.g. local/dev)
# STS_SSL_VERIFY=true

# Output directory for HTML/JSON reports (default: reports/)
# REPORT_DIR=reports
